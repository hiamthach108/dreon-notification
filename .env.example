# Application Configuration
APP_NAME=dreon-notification
APP_VERSION=1.0.0
HTTP_HOST=localhost
HTTP_PORT=8080
GRPC_PORT=9090

# Cache Configuration
CACHE_DEFAULT_EXPIRE_TIME_SEC=3600
CACHE_CLEANUP_INTERVAL_HOUR=24

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL Configuration
POSTGRES_CONNECTION_NAME=
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DBNAME=dreon_notification
POSTGRES_SSL=false
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_MAX_OPEN_CONNS=50

# Email (Resend)
EMAIL_SENDER=noreply@yourdomain.com
EMAIL_TEMPLATE_DIR=templates/email
EMAIL_RESEND_API_KEY=

# SMS (Twilio). Leave empty to use MockClient (SMS calls will return "not configured").
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_TEMPLATE_DIR=templates/sms

# Logging Configuration
LOG_LEVEL=info

# RabbitMQ. Use 127.0.0.1 when running the app on your host (avoids IPv6 ::1 connection refused); use rabbitmq when app runs in Docker.
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/